local paintBtn = createSectionButton("Paint", 1, SideBar)

-- 創建自動攻擊按鈕
local autoAttackBtn = createButton("自動攻擊: 關", 1, paintContent, 50)

-- 創建固定速度按鈕
local speedLockBtn = createButton("固定速度: 關", 2, paintContent, 50)

-- 自動攻擊按鈕功能
autoAttackBtn.MouseButton1Click:Connect(function()
    autoAttackEnabled = not autoAttackEnabled
    
    if autoAttackEnabled then
        autoAttackBtn.Text = "自動攻擊: 開"
        autoAttackBtn.BackgroundColor3 = Color3.fromRGB(60, 180, 60)
        
        -- 開始自動攻擊循環
        autoAttackConnection = RunService.Heartbeat:Connect(function()
            local targetPlayer = findNearestPlayer()
            if targetPlayer then
                attackPlayer(targetPlayer)
            end
        end)
    else
        autoAttackBtn.Text = "自動攻擊: 關"
        autoAttackBtn.BackgroundColor3 = Color3.fromRGB(80, 140, 220)
        
        -- 停止自動攻擊
        if autoAttackConnection then
            autoAttackConnection:Disconnect()
            autoAttackConnection = nil
        end
    end
end)

-- 固定速度按鈕功能
speedLockBtn.MouseButton1Click:Connect(function()
    speedLockEnabled = not speedLockEnabled
    
    if speedLockEnabled then
        speedLockBtn.Text = "固定速度: 開"
        speedLockBtn.BackgroundColor3 = Color3.fromRGB(60, 180, 60)
        
        -- 保存原始速度
        if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
            originalWalkSpeed = LocalPlayer.Character.Humanoid.WalkSpeed
        end
        
        -- 開始速度鎖定
        speedLockConnection = RunService.Heartbeat:Connect(function()
            if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
                LocalPlayer.Character.Humanoid.WalkSpeed = 50
            end
        end)
    else
        speedLockBtn.Text = "固定速度: 關"
        speedLockBtn.BackgroundColor3 = Color3.fromRGB(80, 140, 220)
        
        -- 停止速度鎖定並恢復原始速度
        if speedLockConnection then
            speedLockConnection:Disconnect()
            speedLockConnection = nil
        end
        
        if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") and originalWalkSpeed then
            LocalPlayer.Character.Humanoid.WalkSpeed = originalWalkSpeed
        end
    end
end)

-- Paint分區按鈕點擊事件
paintBtn.MouseButton1Click:Connect(function()
