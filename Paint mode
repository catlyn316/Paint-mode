-- ================================================================
-- Ragdoll 偵測（三重判斷）
-- ================================================================
local function isRagdoll(char)
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum then return true end
    if hum.PlatformStand then return true end
    local rv = char:FindFirstChild("Ragdoll")
    if rv and rv:IsA("BoolValue") and rv.Value then return true end
    if hum:GetState() == Enum.HumanoidStateType.Physics then return true end
    return false
end

-- ================================================================
-- 收集場上所有活著的非玩家 NPC
-- ================================================================
local function getAllNPCs()
    local list = {}
    for _, obj in ipairs(Workspace:GetDescendants()) do
        if obj:IsA("Humanoid") and obj.Health > 0 then
            local char = obj.Parent
            local isPlayer = false
            for _, p in ipairs(Players:GetPlayers()) do
                if p.Character == char then isPlayer = true; break end
            end
            if not isPlayer and char:FindFirstChild("HumanoidRootPart") then
                table.insert(list, char)
            end
        end
    end
    return list
end

-- 場上是否全部 ragdoll
local function allNPCsRagdoll()
    local npcs = getAllNPCs()
    if #npcs == 0 then return false end
    for _, char in ipairs(npcs) do
        if not isRagdoll(char) then return false end
    end
    return true
end

-- 找最近的非 ragdoll NPC，可排除某個目標
local function findNearestNPC(exclude)
    local root = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not root then return nil end
    local nearest, bestDist = nil, math.huge
    for _, char in ipairs(getAllNPCs()) do
        if char ~= exclude and not isRagdoll(char) then
            local d = (char.HumanoidRootPart.Position - root.Position).Magnitude
            if d < bestDist then bestDist = d; nearest = char end
        end
    end
    return nearest
end

-- ================================================================
-- 傳送到 NPC 旁邊並讓角色身體面向 NPC
-- 只改 HumanoidRootPart CFrame，不動攝影機，不強制 shiftlock
-- ================================================================
local function teleportToNPC(npc)
    local npcRoot = npc and npc:FindFirstChild("HumanoidRootPart")
    local myRoot  = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not npcRoot or not myRoot then return end

    local npcPos = npcRoot.Position

    -- NPC 正前方 3 格站位（水平方向，Y 跟 NPC 齊）
    local behind   = npcRoot.CFrame.LookVector
    local spawnPos = Vector3.new(
        npcPos.X + behind.X * 3,
        npcPos.Y,
        npcPos.Z + behind.Z * 3
    )

    -- 計算角色要朝向 NPC 的水平方向（只旋轉 Y 軸，不影響攝影機）
    local lookDir = (npcPos - spawnPos)
    lookDir = Vector3.new(lookDir.X, 0, lookDir.Z).Unit

    -- 用 fromMatrix 純旋轉角色身體朝向，攝影機完全不受影響
    local rightVec = lookDir:Cross(Vector3.new(0, 1, 0))
    myRoot.CFrame = CFrame.fromMatrix(spawnPos, rightVec, Vector3.new(0, 1, 0), -lookDir)
end

-- ================================================================
-- 攻擊：直接呼叫遊戲的 slap Remote
-- 找 Left Arm → 找 HumanoidRootPart 作為 hitPart
-- ================================================================
local function attackNPC(npc)
    if not npc then return end
    local hitPart = npc:FindFirstChild("Left Arm") or npc:FindFirstChild("HumanoidRootPart")
    if not hitPart then return end
    pcall(function()
        game:GetService("ReplicatedStorage").Remotes.tool.hit:FireServer("slap", { Instance = hitPart })
    end)
end

-- ================================================================
-- 固定速度
-- ================================================================
local function startSpeedLock()
    local hum = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid")
    if hum then originalWalkSpeed = hum.WalkSpeed end
    speedLockConnection = RunService.Heartbeat:Connect(function()
        local h = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid")
        if h then h.WalkSpeed = 50 end
    end)
end

local function stopSpeedLock()
    if speedLockConnection then speedLockConnection:Disconnect(); speedLockConnection = nil end
    local h = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid")
    if h and originalWalkSpeed then h.WalkSpeed = originalWalkSpeed end
end

