local function createSectionButton(text, parent)
    local btn = Instance.new("TextButton", parent)
    btn.Size = UDim2.new(0, 120, 0, 45)
    btn.Text = text
    btn.BackgroundColor3 = Color3.fromRGB(85, 85, 105)
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.Font = Enum.Font.GothamBold
    btn.TextSize = 16
    btn.BorderSizePixel = 0
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 10)
    local s = Instance.new("UIStroke", btn)
    s.Color = Color3.fromRGB(150, 180, 255); s.Thickness = 1; s.Transparency = 0.6
    btn.MouseEnter:Connect(function()  btn.BackgroundColor3 = Color3.fromRGB(105,105,125); s.Transparency=0.3 end)
    btn.MouseLeave:Connect(function()  btn.BackgroundColor3 = Color3.fromRGB(85, 85, 105);  s.Transparency=0.6 end)
