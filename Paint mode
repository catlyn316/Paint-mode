-- ================================================================
-- 自動攻擊邏輯
--
-- 每次 Heartbeat 觸發一次：
--   1. 全體 ragdoll → 暫停，玩家自由活動
--   2. 目標 ragdoll / 死亡 → 換目標
--   3. 超過 3 秒 → 換下一個最近目標
--   4. 每 0.15 秒：傳送到目標旁邊並面向 → FireServer slap
-- ================================================================
autoAttackBtn.MouseButton1Click:Connect(function()
    autoAttackEnabled = not autoAttackEnabled

    if autoAttackEnabled then
        autoAttackBtn.Text = "自動傳送NPC: 開"
        autoAttackBtn.BackgroundColor3 = Color3.fromRGB(60, 180, 60)

        local currentTarget   = nil
        local targetStartTime = 0
        local lastActionTime  = 0
        local wasPaused       = false

        local ACTION_INTERVAL = 0.15   -- 傳送+攻擊間隔（秒）
        local TARGET_DURATION = 3      -- 強制換目標時間（秒）

        autoAttackConnection = RunService.Heartbeat:Connect(function()
            local now = tick()

            -- 全體 ragdoll → 暫停
            if allNPCsRagdoll() then
                if not wasPaused then
                    currentTarget = nil
                    wasPaused = true
                end
                return
            end

            -- 從暫停恢復
            if wasPaused then
                wasPaused = false
                currentTarget = nil
            end

            -- 目標有效性檢查
            local targetValid = currentTarget
                and currentTarget.Parent ~= nil
                and currentTarget:FindFirstChildOfClass("Humanoid")
                and currentTarget:FindFirstChildOfClass("Humanoid").Health > 0
                and not isRagdoll(currentTarget)

            -- 需要換目標
            local shouldSwitch = (not targetValid)
                or (now - targetStartTime >= TARGET_DURATION)

            if shouldSwitch then
                local exclude = targetValid and currentTarget or nil
                local next = findNearestNPC(exclude)
                if next then
                    currentTarget   = next
                    targetStartTime = now
                else
                    currentTarget = nil
                    return
                end
            end

            -- 傳送 + 攻擊（依冷卻）
            if currentTarget and (now - lastActionTime >= ACTION_INTERVAL) then
                lastActionTime = now
                teleportToNPC(currentTarget)    -- 傳送過去並面向 NPC
                attackNPC(currentTarget)        -- FireServer slap
            end
        end)

    else
        autoAttackBtn.Text = "自動傳送到NPC: 關"
        autoAttackBtn.BackgroundColor3 = Color3.fromRGB(80, 140, 220)
        if autoAttackConnection then
            autoAttackConnection:Disconnect()
            autoAttackConnection = nil
        end
    end
end)

